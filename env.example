# ═══════════════════════════════════════════
#  RAZI-NOVA SOLUTIONS — Environment Variables
#  Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# Server
PORT=3000

# Manager PIN (same as kiosk)
MANAGER_PIN=1234

# ── TWILIO (SMS & WhatsApp) ──────────────────
# Get these at console.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_PHONE=+12105551234
TWILIO_WHATSAPP=+14155238886

# ── OPENAI (AI Shopping Lists & Templates) ──
# Get at platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── DATABASE ─────────────────────────────────
# SQLite file (auto-created)
DB_PATH=./razco.db
